{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/aws-healthlake/main/json-schema/SseConfiguration.json",
  "title": "SseConfiguration",
  "description": "AWS HealthLake SseConfiguration",
  "type": "object",
  "properties": {
    "KmsEncryptionConfig": {
      "type": "object",
      "properties": {
        "CmkType": {
          "type": "string",
          "enum": [
            "CUSTOMER_MANAGED_KMS_KEY",
            "AWS_OWNED_KMS_KEY"
          ]
        },
        "KmsKeyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 400,
          "pattern": "(arn:aws((-us-gov)|(-iso)|(-iso-b)|(-cn))?:kms:)?([a-z]{2}-[a-z]+(-[a-z]+)?-\\d:)?(\\d{12}:)?(((key/)?[a-zA-Z0-9-_]+)|(alias/[a-zA-Z0-9:/_-]+))"
        }
      },
      "required": [
        "CmkType"
      ]
    }
  },
  "required": [
    "KmsEncryptionConfig"
  ]
}