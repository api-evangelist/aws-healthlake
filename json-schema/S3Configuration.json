{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/aws-healthlake/main/json-schema/S3Configuration.json",
  "title": "S3Configuration",
  "description": "AWS HealthLake S3Configuration",
  "type": "object",
  "properties": {
    "S3Uri": {
      "type": "string",
      "maxLength": 1024,
      "pattern": "s3://[a-z0-9][\\.\\-a-z0-9]{1,61}[a-z0-9](/.*)?"
    },
    "KmsKeyId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400,
      "pattern": "(arn:aws((-us-gov)|(-iso)|(-iso-b)|(-cn))?:kms:)?([a-z]{2}-[a-z]+(-[a-z]+)?-\\d:)?(\\d{12}:)?(((key/)?[a-zA-Z0-9-_]+)|(alias/[a-zA-Z0-9:/_-]+))"
    }
  },
  "required": [
    "S3Uri",
    "KmsKeyId"
  ]
}